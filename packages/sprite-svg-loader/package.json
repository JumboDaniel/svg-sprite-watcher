{
  "name": "svg-sprite-watcher",
  "version": "0.0.1",
  "description": "TypeScript-first SVG sprite generator with framework integrations",
  "type": "module",
  "bin": {
    "svg-sprite-watcher": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./components/react": {
      "types": "./dist/components/react.d.ts",
      "import": "./dist/components/react.mjs"
    },
    "./components/astro": {
      "import": "./dist/components/astro.astro"
    },
    "./types": {
      "types": "./dist/codegen/types.d.ts",
      "import": "./dist/codegen/types.mjs",
      "require": "./dist/codegen/types.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs"
    }
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "commander": "^14.0.3",
    "glob": "^10.3.10",
    "jiti": "^2.6.1",
    "prompts": "^2.4.2",
    "svg-sprite": "^2.0.4"
  },
  "peerDependencies": {
    "svgo": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "svgo": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "@types/svg-sprite": "^0.0.39",
    "@types/vinyl": "^2.0.12",
    "dotenv": "^17.3.1",
    "react": "^19.2.4",
    "typescript": "^5.0.0",
    "unbuild": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
