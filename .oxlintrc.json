{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "error",
    "typescript/no-explicit-any": "warn",
    "typescript/no-unused-vars": "error"
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.astro/**",
    "**/public/sprite.svg",
    "**/*.d.ts",
    "**/pnpm-lock.yaml",
    "**/.gitignore"
  ],
  "overrides": [
    {
      "files": ["**/tests/**/*.ts", "**/*.test.ts", "**/*.spec.ts"],
      "plugins": ["vitest"],
      "rules": {
        "no-console": "off"
      }
    },
    {
      "files": ["**/scripts/**"],
      "rules": {
        "no-console": "off"
      }
    }
  ]
}