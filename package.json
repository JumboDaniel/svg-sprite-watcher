{
  "name": "sprite-svg-loader-workspace",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.0.0",
  "scripts": {
    "build": "pnpm --filter svg-sprite-watcher build",
    "dev:react": "pnpm --filter react dev",
    "dev:vanilla": "pnpm --filter vanilla dev",
    "dev:astro": "pnpm --filter astro dev",
    "dev:next": "pnpm --filter next-js dev",
    "dev:all": "concurrently \"pnpm run dev:react\" \"pnpm run dev:vanilla\" \"pnpm run dev:astro\" \"pnpm run dev:next\"",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint:format:fix:all": "pnpm run lint:fix && pnpm run format:check",
    "test:svg-sprite-watcher": "pnpm --filter svg-sprite-watcher test",
    "test:svg-sprite-watcher:run": "pnpm --filter svg-sprite-watcher test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.50.0"
  }
}
