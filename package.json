{
  "name": "sprite-svg-loader-workspace",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@8.0.0",
  "scripts": {
    "build": "pnpm --filter svg-sprite-generator build",
    "dev:app1": "npm run dev -w @your-scope/app1",
    "dev:app2": "npm run dev -w @your-scope/app2",
    "dev:all": "concurrently \"npm run dev:app1\" \"npm run dev:app2\"",
    "dev:parallel": "pnpm ",
    "lint": "oxlint"
  },
  "devDependencies": {
    "oxlint": "^1.50.0"
  }
}
