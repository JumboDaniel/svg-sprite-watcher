{
  "name": "svg-sprite-generator",
  "version": "0.0.1",
  "description": "TypeScript-first SVG sprite generator with framework integrations",
  "type": "module",
  "bin": {
    "svg-sprite": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./astro": {
      "types": "./dist/astro.d.ts",
      "import": "./dist/astro.mjs"
    },
    "./nextjs": {
      "types": "./dist/nextjs.d.ts",
      "import": "./dist/nextjs.mjs",
      "require": "./dist/nextjs.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs"
    }
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "commander": "^14.0.3",
    "glob": "^10.3.10",
    "inquirer": "^13.2.5",
    "svg-sprite": "^2.0.4"
  },
  "peerDependencies": {
    "svgo": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "svgo": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/svg-sprite": "^0.0.39",
    "@types/vinyl": "^2.0.12",
    "dotenv": "^17.3.1",
    "jiti": "^2.6.1",
    "typescript": "^5.0.0",
    "unbuild": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
